        <!-- ==================== ONLINE: USER QUERY ==================== -->
        <mxCell id="17" value="&lt;b&gt;User Query&lt;/b&gt;&lt;br&gt;facts of a matter (400–1,500 words)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="570" y="908" width="260" height="65" as="geometry" />
        </mxCell>

        <!-- ==================== RETRIEVERS ==================== -->
        <mxCell id="18" value="&lt;b&gt;BM25 Retriever&lt;/b&gt; (retrieval/bm25_retriever.py)&lt;br&gt;① NER-clean query at runtime (spaCy en_core_web_sm)&lt;br&gt;② BM25Okapi.get_scores(tokens) over cached token lists&lt;br&gt;③ max-pool chunk scores → doc-level scores&lt;br&gt;→ top-200 candidate docs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="1038" width="318" height="100" as="geometry" />
        </mxCell>
        <mxCell id="19" value="&lt;b&gt;Dense Retriever&lt;/b&gt; (retrieval/dense_retriever.py)&lt;br&gt;① truncate query → first 300 words&lt;br&gt;② all-mpnet-base-v2 → 768-d query vector&lt;br&gt;③ ChromaDB cosine search (top-2000 chunks)&lt;br&gt;④ similarity × role_weight → max-pool → top-200" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="900" y="1038" width="330" height="100" as="geometry" />
        </mxCell>

        <!-- ==================== HYBRID ==================== -->
        <mxCell id="20" value="&lt;b&gt;Hybrid Retriever — Reciprocal Rank Fusion&lt;/b&gt; (retrieval/hybrid_retriever.py)&lt;br&gt;rrf_score(doc) = Σ  w_i / (k + rank_i(doc))   ·   k = 60  (Cormack et al. 2009)&lt;br&gt;cases: w_bm25 = 1.0, w_dense = 1.0   ·   statutes: w_bm25 = 1.5, w_dense = 1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="1210" width="700" height="65" as="geometry" />
        </mxCell>

        <!-- ==================== RERANKER ==================== -->
        <mxCell id="21" value="&lt;b&gt;Reranker&lt;/b&gt; (retrieval/reranker.py)&lt;br&gt;cross-encoder/ms-marco-MiniLM-L-12-v2 · max_length=512 · batch_size=128 · MPS&lt;br&gt;score top-3 chunks per candidate (query, chunk_text) → max-pool → doc-level score&lt;br&gt;→ top-50 cases · top-30 statutes passed downstream" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="1348" width="700" height="75" as="geometry" />
        </mxCell>

